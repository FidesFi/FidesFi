# Fides Frontier v2 deploy config — Robinhood Chain (chain 4663)
# Basket LOCKED 22 Jul 2026: NVDA, MSFT, TSLA, GOOGL, SPCX — all AMM-tradeable 2-way <1% vs oracle,
# so the agent can rebalance the ENTIRE basket on-chain (no AP sleeve). See research/konsep-fides.md.
# Every address VERIFIED on-chain via cast (symbol/decimals/latestRoundData + live v4 pool liquidity).
# Copy to frontier.env, fill the TODO role values, re-fetch live prices for UNITs, then: source it.
# Deploy: forge script script/DeployFidesFrontier.s.sol:DeployFidesFrontier --rpc-url <RHC> --account fides-deployer --broadcast --legacy --gas-estimate-multiplier 300

# ---- Basket ----
export FIDES_SYMBOLS=NVDA,MSFT,TSLA,GOOGL,SPCX

# ---- Infra (verified: has code) ----
export FIDES_POOL_MANAGER=0x8366a39CC670B4001A1121B8F6A443A643e40951   # Uniswap v4 PoolManager (RHC)
export FIDES_QUOTE=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168          # USDG (6 dec) — the rebalance hub currency

# ---- Stock tokens (verified: symbol + 18 dec) ----
export FIDES_NVDA_TOKEN=0xd0601CE157Db5bdC3162BbaC2a2C8aF5320D9EEC
export FIDES_MSFT_TOKEN=0xe93237C50D904957Cf27E7B1133b510C669c2e74
export FIDES_TSLA_TOKEN=0x322F0929c4625eD5bAd873c95208D54E1c003b2d
export FIDES_GOOGL_TOKEN=0x2e0847E8910a9732eB3fb1bb4b70a580ADAD4FE3
export FIDES_SPCX_TOKEN=0x4a0E65A3EcceC6dBe60AE065F2e7bb85Fae35eEa

# ---- Chainlink feeds (VERIFIED 22 Jul: 8 dec, live, pool price within <1% of oracle) ----
export FIDES_NVDA_ORACLE=0x379EC4f7C378F34a1B47E4F3cbeBCbAC3E8E9F15   # RHNVDA / USD  $206.27
export FIDES_MSFT_ORACLE=0x45C3C877C15E6BA2EBB19eA114Ea508d14C1Af2E   # RHMSFT / USD  $396.40
export FIDES_TSLA_ORACLE=0x4A1166a659A55625345e9515b32adECea5547C38   # RHTSLA / USD  $380.13
export FIDES_GOOGL_ORACLE=0xF6f373a037c30F0e5010d854385cA89185AE638b  # GOOGL / USD   $348.98
export FIDES_SPCX_ORACLE=0xB265810950ba6c5C0Ff821c9963014a56fD8Bffb   # SPCX / USD    $125.06

# ---- Initial units: backing per 1e18 shares, in each token's 18 decimals ----
# ~$100 per leg at the prices above (equal-weight, ~$500 / share). unit_i = (legUsd / price_i) * 1e18.
# ILLUSTRATIVE — RE-FETCH live prices right before deploy and recompute.
export FIDES_NVDA_UNIT=484800000000000000     # 0.4848 NVDA
export FIDES_MSFT_UNIT=252270000000000000     # 0.2523 MSFT
export FIDES_TSLA_UNIT=263070000000000000     # 0.2631 TSLA
export FIDES_GOOGL_UNIT=286550000000000000    # 0.2866 GOOGL
export FIDES_SPCX_UNIT=799620000000000000     # 0.7996 SPCX

# ---- v4 pool params PER STOCK (VERIFIED 22 Jul: exact fee/tickSpacing of the deepest <stock>/USDG pool) ----
# The router hops stock -> USDG -> stock; each hop uses ITS pool's real params. hooks = 0x0 for all.
export FIDES_NVDA_POOLFEE=3000    ; export FIDES_NVDA_POOLSPACING=60
export FIDES_MSFT_POOLFEE=3000    ; export FIDES_MSFT_POOLSPACING=60
export FIDES_TSLA_POOLFEE=3000    ; export FIDES_TSLA_POOLSPACING=60
export FIDES_GOOGL_POOLFEE=3000   ; export FIDES_GOOGL_POOLSPACING=60
export FIDES_SPCX_POOLFEE=10000   ; export FIDES_SPCX_POOLSPACING=200
export FIDES_POOL_HOOKS=0x0000000000000000000000000000000000000000
export FIDES_WIRE_ROUTES=true     # params confirmed -> wire at deploy so the agent can rebalance day 1

# ---- Roles / policy (YOUR addresses — TODO) ----
export FIDES_OWNER=0x0000000000000000000000000000000000000000        # TODO router owner (sets routes)
export FIDES_GUARDIAN=0x0000000000000000000000000000000000000000     # TODO can pause mint / lower cap only
export FIDES_REBALANCER=0x0000000000000000000000000000000000000000   # TODO agent session key
export FIDES_FEE_RECIPIENT=0x0000000000000000000000000000000000000000 # TODO fee -> buyback later
export FIDES_MINT_FEE_BPS=20          # 0.20% (<= 50)
export FIDES_MAX_SLIPPAGE_BPS=100     # 1%
export FIDES_MAX_TURNOVER_BPS=5000    # 50% per rebalance
export FIDES_REBALANCE_COOLDOWN=604800 # 7 days
# oracle safety — stock feeds pause when markets are closed, so this MUST cover heartbeat + weekends.
export FIDES_MAX_ORACLE_AGE=90000     # 25h default — re-check per feed
export FIDES_SEQUENCER_FEED=0x0000000000000000000000000000000000000000  # 0 = skip until RHC's is confirmed
export FIDES_SUPPLY_CEILING=1000000000000000000000000  # 1,000,000 shares hard ceiling
export FIDES_SUPPLY_CAP=1000000000000000000000          # 1,000 shares active cap — START SMALL, raise gradually
