# Fides Frontier deploy config — Robinhood Chain (chain 4663)
# Every address below was VERIFIED on-chain via cast on 2026-07-19 (symbol/decimals/latestRoundData).
# Copy to frontier.env, fill the TODO role/unit values, then: source script/frontier.env
# Deploy: forge script script/DeployFidesFrontier.s.sol:DeployFidesFrontier --rpc-url "$ALCHEMY_RHC_URL" --private-key "$PK" --broadcast

# ---- Basket (default = the verified five; add SPCX once its token address lists) ----
export FIDES_SYMBOLS=NVDA,AMD,MU,PLTR,GOOGL

# ---- Infra (verified: has code) ----
export FIDES_POOL_MANAGER=0x8366a39CC670B4001A1121B8F6A443A643e40951   # Uniswap v4 PoolManager
export FIDES_QUOTE=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168          # USDG (6 dec) — the quote currency

# ---- Stock tokens (verified: symbol + 18 dec) ----
export FIDES_NVDA_TOKEN=0xd0601CE157Db5bdC3162BbaC2a2C8aF5320D9EEC
export FIDES_AMD_TOKEN=0x86923f96303D656E4aa86D9d42D1e57ad2023fdC
export FIDES_MU_TOKEN=0xfF080c8ce2E5feadaCa0Da81314Ae59D232d4afD
export FIDES_PLTR_TOKEN=0x894E1EC2D74FFE5AEF8Dc8A9e84686acCB964F2A
export FIDES_GOOGL_TOKEN=0x2e0847E8910a9732eB3fb1bb4b70a580ADAD4FE3
# export FIDES_SPCX_TOKEN=0x...  # TODO: token registry was down; refetch from docs.robinhood.com/chain/contracts

# ---- Chainlink feeds (verified: 8 dec, live price, RHC "shared-svr" proxy) ----
export FIDES_NVDA_ORACLE=0x379EC4f7C378F34a1B47E4F3cbeBCbAC3E8E9F15   # $202.80
export FIDES_AMD_ORACLE=0x943A29E7ae51A4798823ca9eEd2ed533B2A22C72    # $493.90
export FIDES_MU_ORACLE=0x425EEFdCf05ed6526C3cE61Af99429A228a6d596     # $844.15
export FIDES_PLTR_ORACLE=0x820ABedFF239034956B7A9d2F0a331f9F075eB4c   # $131.69
export FIDES_GOOGL_ORACLE=0xF6f373a037c30F0e5010d854385cA89185AE638b  # $346.62
# export FIDES_SPCX_ORACLE=0xB265810950ba6c5C0Ff821c9963014a56fD8Bffb # feed verified $124.01; enable with SPCX token

# ---- Initial units: backing per 1e18 shares, in each token's 18 decimals ----
# Example below = ~$100 per leg at listed prices (1 share ≈ $500). unit_i = (legUsd / price_i) * 1e18
export FIDES_NVDA_UNIT=493100000000000000     # 0.4931 NVDA
export FIDES_AMD_UNIT=202500000000000000      # 0.2025 AMD
export FIDES_MU_UNIT=118500000000000000       # 0.1185 MU
export FIDES_PLTR_UNIT=759400000000000000     # 0.7594 PLTR
export FIDES_GOOGL_UNIT=288500000000000000    # 0.2885 GOOGL

# ---- v4 pool params (DEFAULTS — confirm per stock/USDG pool before rebalancing) ----
export FIDES_POOL_FEE=3000
export FIDES_POOL_SPACING=60
export FIDES_POOL_HOOKS=0x0000000000000000000000000000000000000000
export FIDES_WIRE_ROUTES=false   # keep false until pool params are confirmed; mint/redeem are live regardless

# ---- Roles / policy (YOUR addresses — TODO) ----
export FIDES_OWNER=0x0000000000000000000000000000000000000000        # TODO router owner
export FIDES_GUARDIAN=0x0000000000000000000000000000000000000000     # TODO can pause mint / lower cap only
export FIDES_REBALANCER=0x0000000000000000000000000000000000000000   # TODO agent session key
export FIDES_FEE_RECIPIENT=0x0000000000000000000000000000000000000000 # TODO fee -> buyback later
export FIDES_MINT_FEE_BPS=20          # 0.20% (<= 50)
export FIDES_MAX_SLIPPAGE_BPS=100     # 1%
export FIDES_MAX_TURNOVER_BPS=5000    # 50% per rebalance
export FIDES_REBALANCE_COOLDOWN=604800 # 7 days
# oracle safety — stock feeds may not update while markets are closed, so this MUST cover
# the feed heartbeat + weekends/holidays. VERIFY each feed's real heartbeat before setting.
export FIDES_MAX_ORACLE_AGE=90000     # 25h default — re-check per feed
# optional L2 sequencer-uptime feed (0 = skip until RHC's is confirmed on-chain)
export FIDES_SEQUENCER_FEED=0x0000000000000000000000000000000000000000
export FIDES_SUPPLY_CEILING=1000000000000000000000000  # 1,000,000 shares hard ceiling
export FIDES_SUPPLY_CAP=100000000000000000000000        # 100,000 shares active cap
